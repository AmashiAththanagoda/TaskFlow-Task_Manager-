# public/.htaccess - Rewrites all requests to the front controller (index.php)
# This file lives inside public/ which is the Apache DocumentRoot.
# So all rewrites target index.php directly - no "public/" prefix needed.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Skip the request if it's an actual file or directory that exists
    # (prevents rewriting real assets like images, CSS, JS)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Rewrite everything else to index.php, passing the URL path as ?url=
    # QSA = append existing query string (preserves ?search=&filter= etc.)
    # L   = stop processing rules after this match
    RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]

    # Root request ( / ) - no url segment, just load the front controller
    RewriteRule ^$ index.php [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Block direct browser access to sensitive file types
<FilesMatch "\.(sql|md|env|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>
